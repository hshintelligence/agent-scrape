{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/stdio.ts"],
  "exclude": ["src/index.ts", "src/index.day4-backup.ts", "test", "node_modules", "dist"]
}
